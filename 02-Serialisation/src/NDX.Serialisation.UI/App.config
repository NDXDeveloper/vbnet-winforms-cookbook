<?xml version="1.0" encoding="utf-8"?>
<configuration>

  <!-- Parametres lus par NDX.Serialisation.Core (module ConfigBdd).
       Correspondent au conteneur Docker MariaDB fourni (port hote 3308). -->
  <appSettings>
    <add key="Bdd.Serveur"     value="127.0.0.1" />
    <add key="Bdd.Port"        value="3308" />
    <add key="Bdd.Base"        value="coffre" />
    <add key="Bdd.Utilisateur" value="coffre_app" />
    <add key="Bdd.MotDePasse"  value="coffre_pwd" />
  </appSettings>

  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8.1" />
  </startup>

</configuration>
