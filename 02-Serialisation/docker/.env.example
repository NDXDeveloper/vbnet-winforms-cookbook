#
#  Copier ce fichier en ".env" puis adapter si besoin :
#       cp .env.example .env        (Linux / Git Bash)
#       Copy-Item .env.example .env (PowerShell)
#
#  Valeurs de DEMONSTRATION uniquement : ne jamais reutiliser telles quelles en prod.
# =============================================================================

# Mot de passe du compte 'root' MariaDB (administration du conteneur).
MARIADB_ROOT_PASSWORD=root_demo_pwd

# Nom de la base creee automatiquement au premier demarrage.
MARIADB_DATABASE=coffre

# Compte applicatif utilise par la bibliotheque et la galerie.
MARIADB_APP_USER=coffre_app
MARIADB_APP_PASSWORD=coffre_pwd

# Port expose sur la machine hote (3308 pour ne pas entrer en conflit avec
# d'autres instances MySQL/MariaDB locales).
MARIADB_HOST_PORT=3308
