<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <appSettings>
    <add key="Bdd.Serveur"     value="127.0.0.1" />
    <add key="Bdd.Port"        value="3313" />
    <add key="Bdd.Base"        value="deploiement" />
    <add key="Bdd.Utilisateur" value="deploiement_app" />
    <add key="Bdd.MotDePasse"  value="deploiement_pwd" />
    <!-- Version "installée" simulée pour la démonstration. -->
    <add key="App.VersionActuelle" value="1.2.0" />
  </appSettings>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8.1" />
  </startup>
</configuration>
