<?xml version="1.0" encoding="utf-8"?>
<configuration>

  <!-- Parametres lus par BoiteAOutils.Core (module ConfigBdd / OutilsReseau).
       Ils correspondent au conteneur Docker MariaDB fourni (port hote 3307). -->
  <appSettings>
    <add key="Bdd.Serveur"     value="127.0.0.1" />
    <add key="Bdd.Port"        value="3307" />
    <add key="Bdd.Base"        value="etabli" />
    <add key="Bdd.Utilisateur" value="etabli_app" />
    <add key="Bdd.MotDePasse"  value="etabli_pwd" />

    <!-- Serveur SMTP de demonstration (l'envoi echoue proprement si absent). -->
    <add key="Smtp.Hote" value="localhost" />
    <add key="Smtp.Port" value="25" />
  </appSettings>

  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8.1" />
  </startup>

</configuration>
