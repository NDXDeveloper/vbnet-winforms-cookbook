# =============================================================================
#  Etabli - Base de demonstration MariaDB (projet 01 - Boite a outils)
# -----------------------------------------------------------------------------
#  Copier ce fichier en ".env" puis adapter si besoin :
#       cp .env.example .env        (Linux / Git Bash)
#       Copy-Item .env.example .env (PowerShell)
#
#  Ces variables sont consommees par docker-compose.yml. Elles ne contiennent
#  que des secrets de DEMONSTRATION : ne jamais reutiliser tels quels en prod.
# =============================================================================

# Mot de passe du compte 'root' MariaDB (administration du conteneur).
MARIADB_ROOT_PASSWORD=root_demo_pwd

# Nom de la base creee automatiquement au premier demarrage.
MARIADB_DATABASE=etabli

# Compte applicatif utilise par la galerie WinForms et la bibliotheque Core.
# (Cree par le script init/01-schema.sql avec l'auth mysql_native_password,
#  garantissant la compatibilite avec le connecteur MySql.Data.)
MARIADB_APP_USER=etabli_app
MARIADB_APP_PASSWORD=etabli_pwd

# Port expose sur la machine hote. On evite 3306 pour ne pas entrer en conflit
# avec une instance MySQL/MariaDB deja installee localement.
MARIADB_HOST_PORT=3307
